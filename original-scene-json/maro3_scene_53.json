[
  {
    "message": "…そして翌朝…"
  },
  {
    "name": "彦麻呂",
    "message": "…。"
  },
  {
    "name": "彦麻呂",
    "message": "…午前８時ですぅ。"
  },
  {
    "name": "彦麻呂",
    "message": "…。"
  },
  {
    "name": "彦麻呂",
    "message": "…今日も良い天気ですねぇ。"
  },
  {
    "name": "友子",
    "message": "オハヨー。"
  },
  {
    "name": "彦麻呂",
    "message": "おはようございます。"
  },
  {
    "name": "友子",
    "message": "昨夜は暑かったー。"
  },
  {
    "name": "彦麻呂",
    "message": "今年一番の熱帯夜だそうですぅ。"
  },
  {
    "name": "友子",
    "message": "金縛りにはならなかった？"
  },
  {
    "name": "彦麻呂",
    "message": "何とか堪え凌ぎましたぁ。"
  },
  {
    "name": "友子",
    "message": "…じゃ、これ。"
  },
  {
    "name": "彦麻呂",
    "message": "やりたい事リストですねぇ。"
  },
  {
    "name": "友子",
    "message": "取り敢えずメモだけ渡しておく。"
  },
  {
    "name": "彦麻呂",
    "message": "…動物園、プール、遊園地？"
  },
  {
    "name": "友子",
    "message": "こっちはいつでもいいからさ。待ってるの慣れてるし、我慢するの好きだし。"
  },
  {
    "name": "彦麻呂",
    "message": "そうやって生前は遠慮ばかり？"
  },
  {
    "name": "友子",
    "message": "え？"
  },
  {
    "name": "彦麻呂",
    "message": "何でもございません、ほほっ。"
  },
  {
    "name": "友子",
    "message": "…変なオジサン。"
  },
  {
    "name": "彦麻呂",
    "message": "本日は実に暇なので。"
  },
  {
    "name": "友子",
    "message": "うん。"
  },
  {
    "name": "彦麻呂",
    "message": "天気も良いですし。"
  },
  {
    "name": "友子",
    "message": "晴れてるねー。"
  },
  {
    "name": "彦麻呂",
    "message": "絶好のレジャー日和だと思いませんか？"
  },
  {
    "name": "友子",
    "message": "…。"
  },
  {
    "name": "彦麻呂",
    "message": "何だかウズウズしてきましたぁ。"
  },
  {
    "name": "友子",
    "message": "も、もしかして…。"
  },
  {
    "name": "彦麻呂",
    "message": "さっそくお出掛けしちゃいましょうか？"
  },
  {
    "name": "友子",
    "message": "い、いいの？"
  },
  {
    "name": "彦麻呂",
    "message": "いいです。"
  },
  {
    "name": "友子",
    "message": "っ、待たなくても大丈夫？"
  },
  {
    "name": "彦麻呂",
    "message": "天気が後押しをしてるじゃないですかぁ。"
  },
  {
    "name": "友子",
    "message": "本当にどっか連れて行ってくれるの？"
  },
  {
    "name": "彦麻呂",
    "message": "それが望みなんですよね？"
  },
  {
    "name": "友子",
    "message": "でもお金とか掛かっちゃうよ。"
  },
  {
    "name": "彦麻呂",
    "message": "基本的に一人分で済みそうですし。"
  },
  {
    "name": "友子",
    "message": "私の為に時間を作ってくれるんだ。"
  },
  {
    "name": "彦麻呂",
    "message": "ですから、暇なので。"
  },
  {
    "name": "友子",
    "message": "嬉しいなー、嬉しいなー。"
  },
  {
    "name": "彦麻呂",
    "message": "…あの。"
  },
  {
    "name": "友子",
    "message": "なに？"
  },
  {
    "name": "彦麻呂",
    "message": "もしかして友子ちゃんは。"
  },
  {
    "name": "友子",
    "message": "うんうん。"
  },
  {
    "name": "彦麻呂",
    "message": "思い残した事だらけなのでは？"
  },
  {
    "name": "友子",
    "message": "別に。"
  },
  {
    "name": "彦麻呂",
    "message": "…。"
  },
  {
    "name": "友子",
    "message": "貧乏で夢も希望もなかったし、もうバイトもしなくて済むし、嫌いな勉強もパスできたし、こっちとサヨナラができて、すっきり。"
  },
  {
    "name": "彦麻呂",
    "message": "…本当ですかぁ？"
  },
  {
    "name": "友子",
    "message": "それより早く行こ。"
  },
  {
    "name": "彦麻呂",
    "message": "どこに行きましょうか？"
  },
  {
    "name": "友子",
    "message": "オジサンが選んでいーよ。"
  },
  {
    "name": "彦麻呂",
    "message": "それでは僭越ながら…。"
  },
  {
    "name": "彦麻呂",
    "message": "ラブホ。"
  },
  {
    "name": "友子",
    "message": "ラブホ？"
  },
  {
    "name": "彦麻呂",
    "message": "はい。"
  },
  {
    "name": "友子",
    "message": "なに、それ？"
  },
  {
    "name": "彦麻呂",
    "message": "大人の社交場ですぅ。"
  },
  {
    "name": "友子",
    "message": "おとなのしゃこうじょう？"
  },
  {
    "name": "彦麻呂",
    "message": "軽～い冗談です、ほほっ。"
  },
  {
    "name": "友子",
    "message": "いいなー、いいなー。"
  },
  {
    "name": "彦麻呂",
    "message": "は？"
  },
  {
    "name": "友子",
    "message": "知らないけど面白そー。"
  },
  {
    "name": "彦麻呂",
    "message": "…。"
  },
  {
    "name": "友子",
    "message": "連れて行ってくれるならそこでもいい。"
  },
  {
    "name": "彦麻呂",
    "message": "大人になったら行きましょうかぁ。"
  },
  {
    "name": "友子",
    "message": "もう大人だし。"
  },
  {
    "name": "彦麻呂",
    "message": "そうは見えませんけどねぇ。"
  },
  {
    "name": "友子",
    "message": "行ってみたいなー、行ってみたいなー。"
  },
  {
    "name": "彦麻呂",
    "message": "また今度という事で。"
  },
  {
    "name": "友子",
    "message": "今度っていつぅ？"
  },
  {
    "name": "彦麻呂",
    "message": "友子ちゃんが良い子にしていたら。"
  },
  {
    "name": "友子",
    "message": "約束だよ。"
  },
  {
    "name": "彦麻呂",
    "message": "約束ですぅ。"
