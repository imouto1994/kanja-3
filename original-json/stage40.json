[
  {
    "message": "…そして８月某日…"
  },
  {
    "name": "彦麻呂",
    "message": "…。"
  },
  {
    "name": "彦麻呂",
    "message": "…今日も暑いでおじゃるねぇ。"
  },
  {
    "message": "とん、とん…。"
  },
  {
    "name": "咲美",
    "message": "おーい。"
  },
  {
    "name": "彦麻呂",
    "message": "…あれぇ？"
  },
  {
    "name": "咲美",
    "message": "入るよー。"
  },
  {
    "message": "がらがらがらっ。"
  },
  {
    "name": "咲美",
    "message": "よいしょ、と。"
  },
  {
    "name": "彦麻呂",
    "message": "ここのところ毎日ですねぇ。"
  },
  {
    "name": "咲美",
    "message": "うん。"
  },
  {
    "name": "彦麻呂",
    "message": "現場からけっこう距離があるのに。"
  },
  {
    "name": "咲美",
    "message": "続けてたら習慣になっちゃった。一日に一回は顔を出さないと、何だか気持ちが悪くてさー。"
  },
  {
    "name": "彦麻呂",
    "message": "今日もここでお弁当ですかぁ？"
  },
  {
    "name": "咲美",
    "message": "もちろんそのつもりで来た。"
  },
  {
    "name": "彦麻呂",
    "message": "現場のお仲間は不思議に思ってます。昼になるといつも姿を消す、綾瀬オッパイチーフって。"
  },
  {
    "name": "咲美",
    "message": "…オッパイだけ余計だ。"
  },
  {
    "name": "彦麻呂",
    "message": "例えばの話ですから、ほほっ。"
  },
  {
    "name": "咲美",
    "message": "心配をしなくてもへーき。日々のコミュニケーションはバッチリで、公私共に良好な関係を築いてるんだから。"
  },
  {
    "name": "彦麻呂",
    "message": "それなら宜しいですが。"
  },
  {
    "name": "咲美",
    "message": "あとここの扇風機が大好きだし。"
  },
  {
    "name": "彦麻呂",
    "message": "…おかしな理由ですねぇ。"
  },
  {
    "name": "咲美",
    "message": "それにヒマしてるセンセーが可哀想だし。"
  },
  {
    "name": "彦麻呂",
    "message": "考え事をしてますから、退屈はしておりません。"
  },
  {
    "name": "咲美",
    "message": "そう？"
  },
  {
    "name": "彦麻呂",
    "message": "さすがに時間の経過はノンビリですが。"
  },
  {
    "name": "咲美",
    "message": "じゃ、お互い何も問題ないという事で。今日も多目に作ってきたから、センセーも一緒に食べよっ。"
  },
  {
    "message": "そう言った咲美。"
  },
  {
    "message": "斜め後ろへチラリと視線を向け。"
  },
  {
    "message": "向日葵のように顔を綻ばせた。"
  },
  {
    "name": "咲美",
    "message": "相変わらず貼ったままだー。"
  },
  {
    "name": "彦麻呂",
    "message": "はい？"
  },
  {
    "name": "咲美",
    "message": "私が描いたセンセーの似顔絵。"
  },
  {
    "name": "彦麻呂",
    "message": "奥さんが自分で貼ったんじゃないですか。"
  },
  {
    "name": "咲美",
    "message": "そのままなのが嬉しいんだよ。"
  },
  {
    "name": "彦麻呂",
    "message": "剥がすのが面倒なだけですぅ。"
  },
  {
    "name": "咲美",
    "message": "そんな事を言っちゃって、けっこうなお気に入り？"
  },
  {
    "name": "彦麻呂",
    "message": "別に。"
  },
  {
    "name": "咲美",
    "message": "照れるなって。"
  },
  {
    "message": "バン、バン。"
  },
  {
    "message": "咲美の手が麻呂の肩へ。"
  },
  {
    "message": "元気一杯で力が有り余ってるのか。"
  },
  {
    "message": "加減というものを知らないでおじゃる。"
  },
  {
    "name": "彦麻呂",
    "message": "…痛いですよぉ。"
  },
  {
    "message": "もちろん麻呂も反撃。"
  },
  {
    "message": "奥さんの後ろへさっと回り込み。"
  },
  {
    "message": "そのまま彼女の腰へを両腕を回した。"
  },
  {
    "name": "彦麻呂",
    "message": "これで組み伏せたら、１ポイント獲得ですぅ。"
  },
  {
    "name": "咲美",
    "message": "甘いなー。"
  },
  {
    "message": "サッ。"
  },
  {
    "name": "彦麻呂",
    "message": "あ、あれっ。"
  },
  {
    "message": "奥さんの素早い動き。"
  },
  {
    "message": "麻呂の腕からスルッと逃げ抜け。"
  },
  {
    "message": "今度はこっちが背後を取られる番。"
  },
  {
    "message": "オッパイごと背中に体重がかけられ。"
  },
  {
    "message": "そのまま麻呂の身体を潰しに掛かる。"
  },
  {
    "name": "彦麻呂",
    "message": "っ、ポイントは差し上げません。"
  },
  {
    "name": "咲美",
    "message": "狙ってるのはこっち。"
  },
  {
    "message": "ぐいっ。"
  },
  {
    "name": "彦麻呂",
    "message": "え゛…。"
  },
  {
    "message": "堪えてた反動を利用され。"
  },
  {
    "message": "麻呂の身体がひょいっと空に浮く。"
  },
  {
    "name": "咲美",
    "message": "投げは５ポイントだよんっ。"
  },
  {
    "name": "彦麻呂",
    "message": "ひぃ…ん…。"
  },
  {
    "message": "弧を描くように麻呂は持ち上げられ。"
  },
  {
    "message": "そのまま後ろへポイされた。"
  },
  {
    "message": "もちろん彼女なりのサポートも万全で。"
  },
  {
    "message": "床に身体がぶつかる時だけ、ちゃんと胴を支えてくれる。"
  },
  {
    "message": "ドサッ。"
  },
  {
    "name": "彦麻呂",
    "message": "く…ひぃ…っ。"
  },
  {
    "name": "咲美",
    "message": "今日は私がお茶を入れてくるねー。"
  },
  {
    "name": "彦麻呂",
    "message": "…。"
  },
  {
    "name": "彦麻呂",
    "message": "指折り数えて、１、２、３。"
  },
  {
    "name": "彦麻呂",
    "message": "今日を入れて３連敗でおじゃるねぇ…はぁ。"
  },
  {
    "name": "咲美",
    "message": "ごちそうさまー。"
  },
  {
    "name": "彦麻呂",
    "message": "ごちそうさまですぅ。"
  },
  {
    "name": "咲美",
    "message": "…もうお腹イッパイ。"
  },
  {
    "name": "彦麻呂",
    "message": "今日もガッツリ食べましたぁ。"
  },
  {
    "name": "咲美",
    "message": "うん…。"
  },
  {
    "name": "彦麻呂",
    "message": "ずずず…ず。"
  },
  {
    "name": "咲美",
    "message": "センセーはいつも、暑い時に熱いお茶。"
  },
  {
    "name": "彦麻呂",
    "message": "それがいいんですよぉ。"
  },
  {
    "name": "咲美",
    "message": "…汗がドバッと出そう。"
  },
  {
    "name": "彦麻呂",
    "message": "夏場の身体は冷やさないほうが良いです。女性である奥さんは、特に気を付けましょう。"
  },
  {
    "name": "咲美",
    "message": "…お医者さんみたいな事を言ってる。"
  },
  {
    "name": "彦麻呂",
    "message": "ほほっ。"
  },
  {
    "name": "咲美",
    "message": "ちなみに今週末だね。"
  },
  {
    "name": "彦麻呂",
    "message": "はい？"
  },
  {
    "name": "咲美",
    "message": "プールの約束。"
  },
  {
    "name": "彦麻呂",
    "message": "ですよねぇ。"
  },
  {
    "name": "咲美",
    "message": "何だか楽しみ。"
  },
  {
    "name": "彦麻呂",
    "message": "…楽しみですぅ。"
  },
  {
    "message": "くるりんっ。"
  },
  {
    "name": "彦麻呂",
    "message": "ほっ？"
  },
  {
    "name": "咲美",
    "message": "本当にそう思ってる？"
  },
  {
    "name": "彦麻呂",
    "message": "お、思ってますよ。"
  },
  {
    "message": "くるりんっ。"
  },
  {
    "name": "咲美",
    "message": "ならいいけどさ。"
  },
  {
    "name": "彦麻呂",
    "message": "もう心の準備はできてます。"
  },
  {
    "name": "咲美",
    "message": "すっぽかしたら、オチンポ千切る。"
  },
  {
    "name": "彦麻呂",
    "message": "ち、ちゃんと行きますって。"
  },
  {
    "name": "咲美",
    "message": "待ち合わせは朝の８時だよ。"
  },
  {
    "name": "彦麻呂",
    "message": "はい。"
  },
  {
    "name": "咲美",
    "message": "場所は？"
  },
  {
    "name": "彦麻呂",
    "message": "当医院を出て目と鼻の先の…。"
  },
  {
    "name": "咲美",
    "message": "センセーがすっぽかしたら、すぐここに踏み込める場所。"
  },
  {
    "name": "彦麻呂",
    "message": "…信用がないですねぇ。"
  },
  {
    "name": "咲美",
    "message": "寝坊とかもあるっしょ？"
  },
  {
    "name": "彦麻呂",
    "message": "そりゃまあ確かに。"
  },
  {
    "name": "咲美",
    "message": "…車を借りて迎えに来る。"
  },
  {
    "name": "彦麻呂",
    "message": "宜しくお願いしますぅ。"
  },
  {
    "name": "咲美",
    "message": "本当ならここにお泊まりして、万全を期したいところだけど。今回はマー君が一緒だし、センセーにまで手が回らない。"
  },
  {
    "name": "彦麻呂",
    "message": "何だか仕事の段取りをしてるみたいです。"
  },
  {
    "name": "咲美",
    "message": "自分でもちょっとそう思った。"
  },
  {
    "name": "彦麻呂",
    "message": "奥さんも楽しんで下さいな。"
  },
  {
    "name": "咲美",
    "message": "…。"
  },
  {
    "name": "彦麻呂",
    "message": "出来る限りの協力は致しますので。"
  },
  {
    "name": "咲美",
    "message": "…アリガト。"
  },
  {
    "name": "彦麻呂",
    "message": "お供をするからには、ベストを尽くします。"
  },
  {
    "name": "咲美",
    "message": "惚れ直しちゃった。"
  },
  {
    "name": "彦麻呂",
    "message": "それくらい当然の事ですよぉ。"
  },
  {
    "name": "咲美",
    "message": "雪菜ちゃんも来るしね。"
  },
  {
    "name": "彦麻呂",
    "message": "は？"
  },
  {
    "name": "咲美",
    "message": "私も協力してあげるよ。"
  },
  {
    "name": "彦麻呂",
    "message": "何をですか？"
  },
  {
    "name": "咲美",
    "message": "…。"
  },
  {
    "name": "咲美",
    "message": "…何でもない。"
  },
  {
    "message": "そう言った咲美。"
  },
  {
    "message": "ポケットをごそごそまさぐり。"
  },
  {
    "message": "一枚の写真をテーブルの上へ。"
  },
  {
    "name": "咲美",
    "message": "…プレゼント。"
  },
  {
    "name": "彦麻呂",
    "message": "ほっ？"
  },
  {
    "name": "咲美",
    "message": "猫カフェに付き合ってもらった時の写真。"
  },
  {
    "name": "彦麻呂",
    "message": "よく撮れてますぅ。"
  },
  {
    "name": "咲美",
    "message": "センセーって人気者だねぇ。"
  },
  {
    "name": "彦麻呂",
    "message": "は？"
  },
  {
    "name": "咲美",
    "message": "私だけじゃなく猫にも。"
  },
  {
    "name": "彦麻呂",
    "message": "…確かに群がって来ましたが。"
  },
  {
    "name": "咲美",
    "message": "マタタビの匂いとかさせてる？"
  },
  {
    "name": "彦麻呂",
    "message": "まさかぁ。"
  },
  {
    "name": "咲美",
    "message": "店の人もビックリしてた。"
  },
  {
    "name": "彦麻呂",
    "message": "やはり人柄ですかねぇ。"
  },
  {
    "name": "咲美",
    "message": "…自分で言うかな。"
  },
  {
    "name": "彦麻呂",
    "message": "誰も言ってくれませんから。"
  },
  {
    "name": "咲美",
    "message": "そんなの本当は気にしてないクセに。"
  },
  {
    "name": "彦麻呂",
    "message": "はい？"
  },
  {
    "name": "咲美",
    "message": "他人の評判とか。"
  },
  {
    "name": "彦麻呂",
    "message": "商売上に於いては大切な事ですので。"
  },
  {
    "name": "咲美",
    "message": "…それは確かにそうかもね。"
  },
  {
    "name": "彦麻呂",
    "message": "ご理解頂けて良かったですぅ。"
  },
  {
    "name": "咲美",
    "message": "私も努力しよ。"
  },
  {
    "name": "彦麻呂",
    "message": "何をですかぁ？"
  },
  {
    "name": "咲美",
    "message": "マー君から人柄まで愛されるように。"
  },
  {
    "name": "彦麻呂",
    "message": "奥さんなら大丈夫ですよ。"
  },
  {
    "name": "咲美",
    "message": "なら私も自分で言ってみる。"
  },
  {
    "name": "彦麻呂",
    "message": "どうぞ、どうぞ。"
  },
  {
    "name": "咲美",
    "message": "私は大丈夫だぞー。"
  },
  {
    "name": "彦麻呂",
    "message": "はい。"
  },
  {
    "name": "咲美",
    "message": "だから週末は頑張るぞー。"
  },
  {
    "name": "彦麻呂",
    "message": "頑張りましょう。"
  },
  {
    "name": "咲美",
    "message": "頑張ってマー君と仲良くするぞー。"
  },
  {
    "name": "彦麻呂",
    "message": "…。"
  },
  {
    "name": "咲美",
    "message": "えい、えい、おー。"
  },
  {
    "name": "彦麻呂",
    "message": "…あの。"
  },
  {
    "name": "咲美",
    "message": "なに？"
  },
  {
    "name": "彦麻呂",
    "message": "ちょっとこっちを向いてくれません？"
  },
  {
    "message": "くるりんっ。"
  },
  {
    "name": "咲美",
    "message": "なーにー？"
  },
  {
    "name": "彦麻呂",
    "message": "魂が抜けたような顔をしてますが。"
  },
  {
    "name": "咲美",
    "message": "そっかな？"
  },
  {
    "name": "彦麻呂",
    "message": "見事に脱力してます。"
  },
  {
    "name": "咲美",
    "message": "これが本当の私です。"
  },
  {
    "name": "彦麻呂",
    "message": "何から何まで間延びしてますねぇ。"
  },
  {
    "name": "咲美",
    "message": "こんな顔はセンセーにしか見せられない。"
  },
  {
    "name": "彦麻呂",
    "message": "いつも気が張ってますから。"
  },
  {
    "name": "咲美",
    "message": "…。"
  },
  {
    "name": "咲美",
    "message": "…何となくわかったよ。"
  },
  {
    "name": "彦麻呂",
    "message": "はい？"
  },
  {
    "name": "咲美",
    "message": "どーしてセンセーが猫にモテるのか。"
  },
  {
    "name": "彦麻呂",
    "message": "…どーしてでしょ？"
  },
  {
    "name": "咲美",
    "message": "内緒。"
  },
  {
    "name": "彦麻呂",
    "message": "出し惜しみはズルいです。"
  },
  {
    "name": "咲美",
    "message": "勿体なくて言えない。"
  },
  {
    "name": "彦麻呂",
    "message": "参考にするので、教えて下さいな。"
  },
  {
    "name": "咲美",
    "message": "言ったらなくなっちゃいそうで、恐い。"
  },
  {
    "name": "彦麻呂",
    "message": "意味不明ですねぇ。"
  },
  {
    "name": "咲美",
    "message": "さて、と…。"
  },
  {
    "name": "咲美",
    "message": "もう、行く。"
  },
  {
    "name": "彦麻呂",
    "message": "わかりましたぁ。"
  },
  {
    "name": "咲美",
    "message": "明日もまた来るから。"
  },
  {
    "name": "彦麻呂",
    "message": "楽しみにしてます。"
  },
  {
    "name": "咲美",
    "message": "お弁当の中身は何がいいかな？"
  },
  {
    "name": "彦麻呂",
    "message": "そうですねぇ…。"
  },
  {
    "name": "咲美",
    "message": "何でもって返事は無しで。"
  },
  {
    "name": "彦麻呂",
    "message": "奥さんが作るものなら何でも。"
  },
  {
    "name": "咲美",
    "message": "…言った尻からそれかい。"
  },
  {
    "name": "彦麻呂",
    "message": "本当にそう思っちゃうんですよ。"
  },
  {
    "name": "咲美",
    "message": "じゃ、ウナギの蒲焼きを詰め込んでくる。"
  },
  {
    "name": "彦麻呂",
    "message": "ウ、ウナギ？"
  },
  {
    "name": "咲美",
    "message": "週末に向けて精が付くように。"
  },
  {
    "name": "彦麻呂",
    "message": "そっち方面の元気も必要なんですか？"
  },
  {
    "name": "咲美",
    "message": "…。"
  },
  {
    "name": "咲美",
    "message": "…やっぱりやめた。"
  },
  {
    "name": "彦麻呂",
    "message": "は？"
  },
  {
    "name": "咲美",
    "message": "精をつけて貰うのは、マー君だけでいいや。"
  },
  {
    "name": "彦麻呂",
    "message": "い、いえ…私もぉ…。"
  },
